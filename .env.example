# --- Configuración del Bot Sapienza ---

# Obtén tu API key gratis en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu-api-key-aqui

# Modelo a usar (opcional, default: gemini-2.5-flash)
# Opciones: gemini-2.5-flash (rápido/barato), gemini-2.5-pro (más capaz)
GEMINI_MODEL=gemini-2.5-flash

# Temperatura (0.0 = determinista, 1.0 = creativo). 0.4 es buen balance para asesoría.
GEMINI_TEMPERATURE=0.4
