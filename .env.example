# --- Configuración del Bot Sapienza ---

# Obtén tu API key gratis en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu-api-key-aqui

# Twilio
TWILIO_ACCOUNT_SID=tu-account-sid
TWILIO_AUTH_TOKEN=tu-auth-token

# CRM: URL del Apps Script desplegado como Web App
# Ejemplo: https://script.google.com/macros/s/XXXXX/exec
APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbxT78fyBk_uGYJZa00h_Ux4FJIxnw8YwEMv4tDh6xLaPT-Lo4JAftw64LyFA7Burm0VyQ/exec

# Secreto para autenticar llamadas del bot al CRM
# Debe coincidir con la Script Property "BOT_SECRET" en Apps Script
BOT_SECRET=samuel-bot-secret-2026
